-- Show all matches
SELECT * FROM matches;

-- Total goals scored
SELECT SUM(goals_scored) AS total_goals_scored FROM matches;

-- Total goals conceded
SELECT SUM(goals_conceded) AS total_goals_conceded FROM matches;

-- Average goals scored per match
SELECT AVG(goals_scored) AS avg_goals_scored FROM matches;

-- Average goals conceded per match
SELECT AVG(goals_conceded) AS avg_goals_conceded FROM matches;

-- Goal difference per match
SELECT opponent,
       goals_scored - goals_conceded AS goal_difference
FROM matches;

-- Best offensive match (most goals scored)
SELECT opponent, goals_scored
FROM matches
ORDER BY goals_scored DESC
LIMIT 1;

-- Worst defensive match (most goals conceded)
SELECT opponent, goals_conceded
FROM matches
ORDER BY goals_conceded DESC
LIMIT 1;

-- Matches where Chelsea scored more than 2 goals
SELECT * FROM matches
WHERE goals_scored > 2;

-- Opponents sorted by goals scored against them
SELECT opponent, goals_scored
FROM matches
ORDER BY goals_scored DESC;
